{
  "name": "marinantex",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:free-ports && npm run dev:infra && concurrently -n web,api -c cyan,green \"npm run dev:web\" \"npm run dev:api\"",
    "dev:free-ports": "node scripts/free-dev-ports.mjs",
    "dev:infra": "docker compose up -d postgres redis minio",
    "dev:web": "next dev -p 3000",
    "dev:web:editor": "npm run dev -w @marinantex/web",
    "dev:api": "npm run start:dev -w @marinantex/api",
    "build": "next build && npm run build -w @marinantex/api",
    "build:web:editor": "npm run build -w @marinantex/web",
    "lint": "npm run lint -w @marinantex/web && npm run lint -w @marinantex/api",
    "test": "npm run test -w @marinantex/api",
    "smoke:test": "node scripts/smoke-tests.mjs",
    "eval:rag-v3": "node scripts/run-rag-v3-evals.mjs",
    "import:tbmm:laws": "node scripts/import-tbmm-laws.mjs",
    "import:mevzuat:laws": "node scripts/import-mevzuat-laws.mjs",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down -v",
    "docker:logs": "docker compose logs -f",
    "docker:prod-local:up": "docker compose -f docker-compose.prod-local.yml up -d --build",
    "docker:prod-local:down": "docker compose -f docker-compose.prod-local.yml down -v",
    "docker:prod-local:logs": "docker compose -f docker-compose.prod-local.yml logs -f"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "dependencies": {
    "@ai-sdk/cohere": "^3.0.22",
    "@ai-sdk/google": "^3.0.34",
    "@ai-sdk/openai": "^3.0.37",
    "ai": "^6.0.105",
    "google-news-url-decoder": "^1.1.3",
    "pdf-parse": "^2.4.5"
  }
}

# ---------------------------------------------------------------------------
# Babylexit v3.0 Backend (FastAPI) - used by docker-compose.yml
# Create a real `.env` (not `.env.example`) at repo root with these values.
# ---------------------------------------------------------------------------

# Supabase (backend service role key - DO NOT expose to frontend)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Direct Postgres connection string for LangGraph checkpointer
DATABASE_URL=

# Redis (docker-compose will use redis://redis:6379 internally)
REDIS_URL=redis://localhost:6379

# Privacy (32-byte key recommended; see backend/.env.example)
PII_ENCRYPTION_KEY=

# Optional LLM providers for backend
ANTHROPIC_API_KEY=
GROQ_API_KEY=

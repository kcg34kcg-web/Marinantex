# ======================================================
# Babylexit Frontend (Next.js) - Environment Template
# ======================================================

# Supabase (frontend-safe)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_ENV=local

# Supabase (server only - do not expose client side)
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SERVICE_KEY=

# AI Providers
GOOGLE_GENERATIVE_AI_API_KEY=
OPENAI_API_KEY=
COHERE_API_KEY=

# Optional cache/rate-limit provider
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=


# ======================================================
# Babylexit Backend (FastAPI) - optional root-level vars
# ======================================================

SUPABASE_URL=
SUPABASE_SERVICE_KEY=
DATABASE_URL=
REDIS_URL=redis://localhost:6379
PII_ENCRYPTION_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# RAG backend base URL (Next.js proxy kullanır — tarayıcıya ifşa edilmez)
RAG_BACKEND_URL=http://localhost:8000

# Infrastructure ports
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# PostgreSQL
POSTGRES_USER=marinantex
POSTGRES_PASSWORD=marinantex
POSTGRES_DB=marinantex
DATABASE_URL=postgresql://marinantex:marinantex@localhost:5432/marinantex?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# MinIO / S3-compatible storage
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET=documents
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET=documents

# Export pipeline
EXPORT_QUEUE_NAME=document-export
EXPORT_URL_TTL_SECONDS=300
EXPORT_OBJECT_RETENTION_HOURS=168

# API hardening
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_LIMIT=120
API_BODY_LIMIT=2mb
CORS_ORIGINS=http://localhost:3000

# Auth baseline
JWT_SECRET=replace_with_a_long_random_secret_for_local_dev
JWT_EXPIRES_IN=15m

# App endpoints
WEB_PORT=3000
API_PORT=4000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

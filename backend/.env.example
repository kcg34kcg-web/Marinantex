# ============================================================================
# Environment Configuration
# Copy this file to .env and fill in your actual values
# ============================================================================

# ============================================================================
# Database (Supabase)
# ============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here
SUPABASE_ANON_KEY=your_anon_key_here

# Postgres Direct Connection (for LangGraph checkpointer)
# Format: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:your_password@your_host:5432/postgres

# ============================================================================
# Redis (Cache & Pub/Sub)
# ============================================================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=  # Leave empty if no password

# ============================================================================
# LLM Providers (Fallback Chain)
# ============================================================================
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...

# ============================================================================
# Privacy & Security
# ============================================================================
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
PII_ENCRYPTION_KEY=your_64_character_hex_key_here

# JWT Secret (for auth tokens if needed)
JWT_SECRET_KEY=your_jwt_secret_here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

# ============================================================================
# Application Settings
# ============================================================================
ENVIRONMENT=development  # development | production
LOG_LEVEL=info  # debug | info | warning | error
DEBUG=true

# API Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# ============================================================================
# Embeddings & Models
# ============================================================================
# HuggingFace model for semantic routing
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
EMBEDDING_DIMENSION=768

# Turkish NLP (optional)
TURKISH_NER_MODEL=  # If using custom Turkish NER

# ============================================================================
# LangGraph & Checkpointer
# ============================================================================
# Checkpoint table name (will be created automatically)
CHECKPOINT_TABLE_NAME=langgraph_checkpoints

# ============================================================================
# Feature Flags (PHASE implementation toggles)
# ============================================================================
ENABLE_PRIVACY_MIDDLEWARE=true
ENABLE_SEMANTIC_ROUTER=true
ENABLE_TIME_TRAVEL=false  # PHASE 3
ENABLE_CITATION_ENGINE=false  # PHASE 4
ENABLE_LIVING_DOCUMENTS=false  # PHASE 4

# ============================================================================
# External Services (Future)
# ============================================================================
# Resmi Gazete scraper
RESMI_GAZETE_API_URL=
RESMI_GAZETE_API_KEY=

# Turkish Court System (UYAP) integration
UYAP_API_URL=
UYAP_API_KEY=

# ============================================================================
# Environment Configuration
# Copy this file to .env and fill in your actual values
# ============================================================================

# ============================================================================
# Database (Supabase)
# ============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here
SUPABASE_ANON_KEY=your_anon_key_here

# Postgres Direct Connection (for LangGraph checkpointer)
# Format: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:your_password@your_host:5432/postgres

# ============================================================================
# Redis (Cache & Pub/Sub)
# ============================================================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=  # Leave empty if no password

# ============================================================================
# LLM Providers (Fallback Chain)
# ============================================================================
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=  # Optional OpenAI-compatible endpoint (e.g. http://localhost:8008/v1)
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...

# ============================================================================
# Privacy & Security
# ============================================================================
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
PII_ENCRYPTION_KEY=your_64_character_hex_key_here

# JWT Secret (for auth tokens if needed)
JWT_SECRET_KEY=your_jwt_secret_here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

# ============================================================================
# Application Settings
# ============================================================================
ENVIRONMENT=development  # development | production
LOG_LEVEL=info  # debug | info | warning | error
DEBUG=true

# API Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# ============================================================================
# Embeddings & Models
# ============================================================================
# Active default (matches infrastructure.config.Settings)
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
EMBEDDING_BASE_URL=  # Optional OpenAI-compatible embeddings endpoint (e.g. http://localhost:8081/v1)
EMBEDDING_API_KEY=
EMBEDDING_BATCH_SIZE=512
EMBEDDING_SEND_DIMENSIONS_PARAM=true
EMBEDDING_FAIL_OPEN_ENABLED=true

# Optional local alternative (if you switch provider/model in code + DB schema)
# EMBEDDING_MODEL=BAAI/bge-m3
# EMBEDDING_DIMENSIONS=1024
# EMBEDDING_BASE_URL=http://localhost:8081/v1
# EMBEDDING_API_KEY=tei-local
# EMBEDDING_SEND_DIMENSIONS_PARAM=false

# RAG v3 reranker (cross-encoder)
RAG_V3_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RAG_V3_RERANKER_ENABLED=true
RAG_V3_CLAIM_MIN_OVERLAP=0.22
RAG_V3_CLAIM_MIN_SUPPORTED_RATIO=0.70
RAG_V3_NO_ANSWER_ON_CLAIM_VERIFICATION_FAIL=true
RAG_V3_HUMAN_REVIEW_ENABLED=true
RAG_V3_FEEDBACK_AUTO_CAPTURE_ENABLED=true
RAG_V3_TENANT_HARD_FAIL_MISSING_BUREAU=true
RAG_V3_MAX_INFLIGHT_REQUESTS=64
RAG_V3_QUEUE_TIMEOUT_MS=1000
RAG_V3_ADMISSION_MAX_QUERY_CHARS=4000
RAG_V3_ADMISSION_MAX_INPUT_TOKENS=6000
RAG_V3_INGEST_CONTRACT_VERSION=rag.v3.ingest.response.v1
RAG_V3_INGEST_SCHEMA_VERSION=rag.v3.ingest.response.schema.v1
RAG_V3_QUERY_CONTRACT_VERSION=rag.v3.query.response.v1
RAG_V3_QUERY_SCHEMA_VERSION=rag.v3.query.response.schema.v1

# Turkish NLP (optional)
TURKISH_NER_MODEL=  # If using custom Turkish NER

# ============================================================================
# LangGraph & Checkpointer
# ============================================================================
# Checkpoint table name (will be created automatically)
CHECKPOINT_TABLE_NAME=langgraph_checkpoints

# ============================================================================
# Feature Flags (PHASE implementation toggles)
# ============================================================================
ENABLE_PRIVACY_MIDDLEWARE=true
ENABLE_SEMANTIC_ROUTER=true
ENABLE_TIME_TRAVEL=false  # PHASE 3
ENABLE_CITATION_ENGINE=false  # PHASE 4
ENABLE_LIVING_DOCUMENTS=false  # PHASE 4

# ============================================================================
# External Services (Future)
# ============================================================================
# Resmi Gazete scraper
RESMI_GAZETE_API_URL=
RESMI_GAZETE_API_KEY=

# Turkish Court System (UYAP) integration
UYAP_API_URL=
UYAP_API_KEY=
